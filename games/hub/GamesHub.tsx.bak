/**
 * games/hub/GamesHub.tsx — Full-Screen Animated Games Hub
 * ────────────────────────────────────────────────────────
 * Warm-themed landing with 4 large section cards.
 * Replaces the flat grid when user first enters Games.
 *
 * Sections:
 *   🎮 Arcade Arena   → onNavigate('arcade')
 *   🔢 Maths World    → onNavigate('maths')
 *   📚 English Kingdom → onNavigate('english')
 *   📖 NCERT Library   → onNavigate('library')
 */

import React, { useEffect, useRef } from 'react';
import { motion } from 'framer-motion';
import SectionCard from './SectionCard';

export type HubSection = 'arcade' | 'maths' | 'english' | 'library';

interface GamesHubProps {
  onNavigate: (section: HubSection) => void;
  /** Student's display name (for greeting) */
  studentName?: string;
}

/* ── Section definitions ──────────────────────── */
const SECTIONS: {
  id: HubSection;
  title: string;
  subtitle: string;
  icon: string;
  gradient: string;
  glowColor: string;
}[] = [
  {
    id: 'arcade',
    title: 'Arcade Arena',
    subtitle: 'Fun brain games!',
    icon: '🎮',
    gradient: 'linear-gradient(135deg, #FF7F50, #FF6347)',
    glowColor: 'rgba(255,127,80,0.35)',
  },
  {
    id: 'maths',
    title: 'Maths World',
    subtitle: 'Numbers & Shapes!',
    icon: '🔢',
    gradient: 'linear-gradient(135deg, #FFD166, #FFB347)',
    glowColor: 'rgba(255,209,102,0.35)',
  },
  {
    id: 'english',
    title: 'English Kingdom',
    subtitle: 'Words & Stories!',
    icon: '📚',
    gradient: 'linear-gradient(135deg, #A8E6CF, #72D8A0)',
    glowColor: 'rgba(168,230,207,0.35)',
  },
  {
    id: 'library',
    title: 'NCERT Library',
    subtitle: 'Books & Textbooks!',
    icon: '📖',
    gradient: 'linear-gradient(135deg, #FFB4A2, #E5989B)',
    glowColor: 'rgba(255,180,162,0.35)',
  },
];

/* ── Animated floating shapes (background decoration) ── */
const FloatingShape: React.FC<{ emoji: string; size: number; x: string; y: string; delay: number }> = ({
  emoji, size, x, y, delay,
}) => (
  <motion.div
    initial={{ opacity: 0, scale: 0 }}
    animate={{ opacity: 0.15, scale: 1, y: [0, -12, 0, 12, 0] }}
    transition={{
      opacity: { delay, duration: 0.6 },
      scale: { delay, duration: 0.4 },
      y: { delay: delay + 0.5, duration: 6 + Math.random() * 4, repeat: Infinity, ease: 'easeInOut' },
    }}
    style={{
      position: 'absolute', left: x, top: y,
      fontSize: size, pointerEvents: 'none', zIndex: 0,
    }}
  >
    {emoji}
  </motion.div>
);

const FLOATERS = [
  { emoji: '⭐', size: 28, x: '8%', y: '15%', delay: 0.2 },
  { emoji: '🌈', size: 32, x: '85%', y: '10%', delay: 0.4 },
  { emoji: '🎨', size: 26, x: '12%', y: '75%', delay: 0.3 },
  { emoji: '🧩', size: 30, x: '90%', y: '70%', delay: 0.5 },
  { emoji: '✨', size: 24, x: '50%', y: '8%', delay: 0.1 },
  { emoji: '🎯', size: 22, x: '75%', y: '85%', delay: 0.6 },
];

const GamesHub: React.FC<GamesHubProps> = ({ onNavigate, studentName }) => {
  /* ── Mascot greeting via SoundProvider ── */
  const spokenRef = useRef(false);
  useEffect(() => {
    if (spokenRef.current) return;
    spokenRef.current = true;
    // Use Web Speech API for playful greeting
    if ('speechSynthesis' in window) {
      const u = new SpeechSynthesisUtterance("Let's Playyyy!");
      u.rate = 1.0; u.pitch = 1.3; u.volume = 0.7;
      speechSynthesis.speak(u);
    }
  }, []);

  return (
    <div style={S.wrapper}>
      {/* Animated warm gradient background */}
      <motion.div
        style={S.bgGradient}
        animate={{
          background: [
            'linear-gradient(135deg, #FFF5E1 0%, #FFE0CC 25%, #FFD6B8 50%, #FFE8D6 75%, #FFF5E1 100%)',
            'linear-gradient(135deg, #FFE8D6 0%, #FFD6B8 25%, #FFCBA4 50%, #FFE0CC 75%, #FFE8D6 100%)',
            'linear-gradient(135deg, #FFF5E1 0%, #FFE0CC 25%, #FFD6B8 50%, #FFE8D6 75%, #FFF5E1 100%)',
          ],
        }}
        transition={{ duration: 8, repeat: Infinity, ease: 'easeInOut' }}
      />

      {/* Floating decorative shapes */}
      {FLOATERS.map((f, i) => (
        <FloatingShape key={i} {...f} />
      ))}

      {/* Title */}
      <motion.div
        initial={{ opacity: 0, y: -20 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ delay: 0.05, duration: 0.5 }}
        style={S.titleBlock}
      >
        <span style={S.titleIcon}>🎪</span>
        <h1 style={S.title}>
          {studentName ? `Hey ${studentName}!` : 'Games Hub'}
        </h1>
        <p style={S.subtitle}>Pick a world and start playing!</p>
      </motion.div>

      {/* Section Cards — single horizontal row */}
      <div style={S.cardsRow}>
        {SECTIONS.map((sec, i) => (
          <SectionCard
            key={sec.id}
            title={sec.title}
            subtitle={sec.subtitle}
            icon={sec.icon}
            gradient={sec.gradient}
            glowColor={sec.glowColor}
            index={i}
            onClick={() => onNavigate(sec.id)}
          />
        ))}
      </div>

      {/* Bottom note */}
      <motion.p
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        transition={{ delay: 0.8 }}
        style={S.footer}
      >
        🛡️ No rankings • No comparison • Pure learning fun
      </motion.p>
    </div>
  );
};

/* ── Styles ─────────────────────────────────────── */
const S: Record<string, React.CSSProperties> = {
  wrapper: {
    display: 'flex',
    flexDirection: 'column',
    alignItems: 'center',
    justifyContent: 'center',
    minHeight: '100vh',
    width: '100%',
    position: 'relative',
    overflow: 'hidden',
    padding: '24px 16px',
    gap: 24,
  },
  bgGradient: {
    position: 'absolute',
    inset: 0,
    zIndex: -1,
  },
  titleBlock: {
    display: 'flex',
    flexDirection: 'column',
    alignItems: 'center',
    gap: 6,
    zIndex: 1,
  },
  titleIcon: {
    fontSize: 'clamp(40px, 6vw, 64px)',
    lineHeight: 1,
  },
  title: {
    fontSize: 'clamp(28px, 4vw, 44px)',
    fontWeight: 900,
    color: '#5B3A29',
    textAlign: 'center',
    margin: 0,
    lineHeight: 1.2,
  },
  subtitle: {
    fontSize: 'clamp(14px, 1.8vw, 18px)',
    fontWeight: 600,
    color: '#8B6F5E',
    textAlign: 'center',
    margin: 0,
  },
  cardsRow: {
    display: 'flex',
    flexDirection: 'row',
    justifyContent: 'center',
    alignItems: 'center',
    gap: 'clamp(16px, 2.5vw, 40px)',
    width: '100%',
    maxWidth: 1200,
    padding: '8px 16px',
    zIndex: 1,
    overflowX: 'auto',
    overflowY: 'hidden',
  },
  footer: {
    fontSize: 12,
    fontWeight: 600,
    color: '#B8927F',
    textAlign: 'center',
    margin: 0,
    zIndex: 1,
  },
};

export default React.memo(GamesHub);
