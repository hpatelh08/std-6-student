/* ═══════════════════════════════════════════════════
   BACK COVER
   ═══════════════════════════════════════════════════ */
const BackCover = memo(forwardRef<HTMLDivElement, { book: BookEntry; totalPages: number; stats: any }>(({ book, totalPages, stats }, ref) => (
